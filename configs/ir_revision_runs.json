{
  "defaults": {
    "backbone_name": "parnet",
    "parnet_weights": "/lustre/groups/crna01/projects/collabs/shared/models/parnet/0.5.0_RBPNet-11M.pt",
    "fasta_path": "resubmission/data/all_vastdb_introns_50fks.fasta",
    "training_env": "/lustre/groups/crna01/projects/collabs/shared/cenvs/parnet_clean",
    "modisco_env": "/lustre/groups/crna01/projects/collabs/shared/cenvs/tfmodisco",
    "interpretation_dirname": "interpretation_fixed",
    "modisco_prefix": "all",
    "modisco_sign_multiplier": 1,
    "n_splits": 5,
    "random_seed": 42,
    "flank_length": 256,
    "batch_size": 64,
    "num_workers": 4,
    "model_kwargs": {
      "feat_dim": 512,
      "attn_hidden": 256,
      "use_attention_pooling": true,
      "use_simple_fusion": false,
      "use_joint_classifier": true,
      "use_middle": false
    },
    "training_kwargs": {
      "lr": 0.0001,
      "backbone_lr_base": 1e-05,
      "llrd_gamma": 0.6,
      "weight_decay": 2e-05,
      "max_epochs": 40,
      "patience": 7,
      "freeze_backbone_initial": true,
      "unfreeze_after_epochs": 3
    },
    "umap_kwargs": {
      "n_neighbors": 50,
      "min_dist": 0.2,
      "n_components": 2,
      "metric": "cosine",
      "random_state": 42
    },
    "pir_nuc_baseline_min": 0
  },
  "runs": {
    "ir_revised": {
      "description": "Base PIR model.",
      "metadata_csv": "resubmission/data/metadata_selected.csv",
      "class_column": "PIR_Nuc_baseline",
      "class_limits": [
        1,
        30
      ],
      "result_dir": "resubmission/results/models/IR/parnet_512_jc_256bp",
      "umap_outputs": [
        "resubmission/results/models/IR/parnet_512_jc_256bp/umap_embeddings.csv"
      ],
      "umap_columns": [
        "UMAP1_IR",
        "UMAP2_IR"
      ]
    }
  }
}
